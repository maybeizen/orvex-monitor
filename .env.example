# Consolidated environment reference for local development.
# Copy to .env at the repo root, or use per-app .env files under apps/*.

# --- API (apps/api) ---
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

WEB_ORIGIN=http://localhost:5173
OAUTH_CALLBACK_BASE_URL=http://localhost:3000

DATABASE_URL=postgresql://orvex:orvex@localhost:5432/orvex
REDIS_URL=redis://localhost:6379

SESSION_SECRET=change-me-to-a-random-string-at-least-32-chars
SESSION_COOKIE_NAME=orvex.sid
SESSION_MAX_AGE_MS=604800000
TRUST_PROXY=true
CSRF_SECRET=

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
EMAIL_FROM=Orvex <noreply@orvex.app>

STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./uploads
STORAGE_PUBLIC_BASE_URL=http://localhost:3000/uploads

S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Worker (apps/worker) ---
# Uses DATABASE_URL, REDIS_URL, WEB_ORIGIN, and SMTP_* from above.

# --- Web (apps/web) ---
# API calls use the Vite dev proxy (/api → localhost:3000); no auth secrets in the browser.
VITE_DOCS_URL=https://docs.orvexmonitor.com/getting-started
