    "@orvex/types": "workspace:*",
    "dotenv": "^16.5.0",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@orvex/config": "workspace:*",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "tsdown": "^0.22.0",
    "typescript": "^5.8.3"
  }
