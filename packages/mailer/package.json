{
  "name": "@orvex/mailer",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown && cp -r src/templates dist/templates",
    "dev": "tsdown --watch --no-clean",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@orvex/logger": "workspace:*",
    "nodemailer": "^7.0.3"
  },
  "devDependencies": {
    "@orvex/config": "workspace:*",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.17",
    "tsdown": "^0.22.0",
    "typescript": "^5.8.3"
  }
}
